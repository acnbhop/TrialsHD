// Shader file
shader shaders/shadowPass.fx

// Vertex format
vxf position HALF3 FLOAT3

// Textures
tex 0 lightMapTexture
tex 1 lightMapTexture
tex 2 lightMapTexture
tex 0 lightMaskTexture
tex 0 lightIndexTexture
tex 0 gbufferMotionVectors
tex 1 gbufferMotionVectors
tex 2 gbufferMotionVectors
tex 0 gbufferMaterialProperties

// Constants
constant matrixWVP 0
constant time 0

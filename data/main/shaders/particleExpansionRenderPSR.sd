// Shader file
shader shaders/particleExpansionRenderPSR.fx

// Vertex format
vxf position HALF4 HALF4
vxf position2 HALF4 HALF4
vxf position3 HALF4 HALF4
vxf position4 HALF4 HALF4
vxf2 position5 FLOAT4 FLOAT4

// Textures
tex 0 mapColor
tex 1 mapNormalHeightAmbient

// Constants
//constant hdrProperties 0
constant fogColor 0


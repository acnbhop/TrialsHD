// Shader file
shader shaders/geometrySkinnedI4ParallaxMask.fx

// Vertex format
vxf position HALF3 FLOAT3
vxf normal DEC3N HALF3
vxf tangent DEC3N HALF3
vxf bitangent DEC3N HALF3
vxf texcoords HALF2 FLOAT2
vxf weights HALF4 FLOAT4
vxf index UBYTE4 UBYTE4

// Textures
tex 0 mapColor
tex 1 mapNormalHeightAmbient
tex 2 mapMaterialProperties

// Constants
constant matrixP 0
constant matrixWV 30
constant materialColor 0
constant materialProperties 0
constant materialParallax 0
constant cameraPosition 0

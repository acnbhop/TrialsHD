// Shader file
shader shaders/lightingMainIDX.fx

// Vertex format
vxf position FLOAT4 FLOAT4
vxf texcoords FLOAT2 FLOAT2
vxf texcoords2 FLOAT3 FLOAT3

// Textures
tex 0 gbufferDepth
tex 0 gbufferColor
tex 0 gbufferNormal
tex 0 gbufferMotionVectors
tex 0 lightIndexTexture

// Constants
constant fogStart 0
constant fogLengthInv 0
constant fogColor 0


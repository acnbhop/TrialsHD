<!--

  Track:
  
    id              = track ID
    type            = {racing | freestyle | crash }
    leaderboard_id  = leaderboard stat view ID
    context_id      = context ID
    fullonly        = true if not in trial mode, false if available in trial mode
    difficulty      = 1 (beginner), 2 (easy), 3 (medium), 4 (hard), 5 (inferno)
    factor          = fault factor for global csore calculation

    Limits:

      pass          = USED ONLY IN RACING AND CRASH - this is used for global score ranking. Ask Jorma.
                      (absolute minimum time in milliseconds)
      
      platinum,         = in racing mode, times to reach medals in this track (milliseconds)
      gold,         in other modes, points to reach medals in this track
      silver
      
      platinum_faults,
      gold_faults,
      silver_faults
	  
	  1000 = sec
	  10 000 = 10 sec
	  60 000 = min
	  3 600 000 = hour
	  
	  
	  MEDAL INFO:
	  
	  pass = silver medal (pass time not used?)
	  silver = gold medal
	  gold = platinum medal
	  platinum = platinum medal

-->
